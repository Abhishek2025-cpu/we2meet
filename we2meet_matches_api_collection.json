            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches?page=1&limit=5",
              "host": ["{{baseUrl}}"], "path": ["api","matches"],
              "query": [{ "key": "page", "value": "1" },{ "key": "limit", "value": "5" }]
            }
          }
        },

        {
          "name": "5. Get Matches — Filter by Age Range (22–30)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('All returned users are in age range 22-30', function () {",
                  "    const data = pm.response.json().data;",
                  "    data.forEach(u => {",
                  "        if (u.age !== null && u.age !== undefined) {",
                  "            pm.expect(u.age).to.be.within(22, 30);",
                  "        }",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches?ageMin=22&ageMax=30",
              "host": ["{{baseUrl}}"], "path": ["api","matches"],
              "query": [{ "key": "ageMin", "value": "22" },{ "key": "ageMax", "value": "30" }]
            }
          }
        },

