            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches?religions=Hindu",
              "host": ["{{baseUrl}}"], "path": ["api","matches"],
              "query": [{ "key": "religions", "value": "Hindu" }]
            }
          }
        },

        {
          "name": "7. Get Matches — Filter Smoking=false",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
