    {
      "name": "⚙️ PREFERENCES — CRUD",
      "item": [
        {
          "name": "15. GET Preferences (initial state)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Data is an object', function () {",
                  "    pm.expect(pm.response.json().data).to.be.an('object');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/matches/preferences", "host": ["{{baseUrl}}"], "path": ["api","matches","preferences"] }
          }
        },

        {
          "name": "16. PATCH Preferences — Save Full Preferences",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Saved preferences returned', function () {",
                  "    const data = pm.response.json().data;",
                  "    pm.expect(data).to.be.an('object');",
                  "    pm.expect(data.ageRange).to.deep.equal({ min: 22, max: 32 });",
                  "    pm.expect(data.religions).to.include('Hindu');",
                  "    pm.expect(data.smoking).to.be.false;",
