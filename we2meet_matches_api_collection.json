    {
      "name": "⚡ MATCHES — Using Saved Preferences",
      "item": [
        {
          "name": "22. Save Preferences Then Get Matches (chained flow)",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Step 1: Save preferences first, then the GET matches request runs",
                  "const baseUrl = pm.collectionVariables.get('baseUrl');",
                  "const token   = pm.collectionVariables.get('authToken');",
                  "",
                  "pm.sendRequest({",
                  "    url: baseUrl + '/api/matches/preferences',",
                  "    method: 'PATCH',",
                  "    header: {",
                  "        'Content-Type': 'application/json',",
                  "        'Authorization': 'Bearer ' + token",
                  "    },",
                  "    body: {",
                  "        mode: 'raw',",
                  "        raw: JSON.stringify({",
                  "            ageRange: { min: 22, max: 35 },",
                  "            religions: ['Hindu'],",
                  "            smoking: false,",
                  "            sortBy: 'matchPercentage'",
                  "        })",
                  "    }",
                  "}, function (err, res) {",
                  "    if (err) { console.error('Pre-save failed:', err); }",
                  "    else { console.log('✅ Preferences pre-saved:', res.json().data); }",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns filtered matches', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.data).to.be.an('array');",
                  "    pm.expect(json.meta).to.have.property('total');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches?ageMin=22&ageMax=35&religions=Hindu&smoking=false&sortBy=matchPercentage",
              "host": ["{{baseUrl}}"], "path": ["api","matches"],
              "query": [
                { "key": "ageMin",    "value": "22" },
                { "key": "ageMax",    "value": "35" },
                { "key": "religions", "value": "Hindu" },
                { "key": "smoking",   "value": "false" },
                { "key": "sortBy",    "value": "matchPercentage" }
              ]
            }
          }
        }
