{
  "info": {
    "_postman_id": "we2meet-matches-api-v1",
    "name": "We2Meet — Matches & Preferences API",
    "description": "Fully automated test collection for the Matches tab + Adjust Preferences API.\n\n**How to use:**\n1. Set the `baseUrl` and `loginPhone` / `loginPassword` collection variables below.\n2. Run the **[SETUP] Login & Capture Token** request first — it auto-saves the Bearer token.\n3. Run any other request — they all use the auto-captured token.\n4. Or hit **Run Collection** to execute every request in order automatically.\n\n**Collection Variables (edit before running):**\n- `baseUrl`       — e.g. `http://localhost:5000`\n- `loginPhone`    — phone number of a registered user\n- `loginPassword` — password of that user",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    { "key": "baseUrl",       "value": "http://localhost:5000", "type": "string" },
    { "key": "loginPhone",    "value": "9999999999",            "type": "string" },
    { "key": "loginPassword", "value": "Test@1234",             "type": "string" },
    { "key": "authToken",     "value": "",                      "type": "string" },
    { "key": "currentUserId", "value": "",                      "type": "string" }
  ],

  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },

  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global pre-request: nothing needed — each request uses {{authToken}}"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Global test: assert every response is valid JSON",
          "pm.test('Response is JSON', function () {",
          "    pm.response.to.be.json;",
          "});",
          "pm.test('success flag is true', function () {",
          "    const json = pm.response.json();",
          "    pm.expect(json.success).to.be.true;",
          "});"
        ]
      }
    }
  ],

  "item": [

    {
      "name": "🔐 AUTH",
      "item": [
        {
          "name": "[SETUP] Login & Capture Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token received', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    // Save token & userId for all subsequent requests",
                  "    pm.collectionVariables.set('authToken', json.token);",
                  "    pm.collectionVariables.set('currentUserId', json.data._id);",
                  "    console.log('✅ Token captured:', json.token.substring(0,30) + '...');",
                  "    console.log('✅ User ID:', json.data._id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"{{loginPhone}}\",\n  \"password\": \"{{loginPassword}}\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/login", "host": ["{{baseUrl}}"], "path": ["api","users","login"] }
          }
        }
      ]
    },

    {
      "name": "📋 FILTER OPTIONS",
      "item": [
        {
          "name": "Get Filter Options (for dropdowns)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('All filter keys present', function () {",
                  "    const data = pm.response.json().data;",
                  "    const keys = ['religions','motherTongues','castes','qualifications','workingWith',",
                  "                  'professions','dietaryPreference','familyStatus','familyType',",
                  "                  'familyValues','maritalStatus'];",
                  "    keys.forEach(k => pm.expect(data).to.have.property(k));",
                  "});",
                  "pm.test('Values are arrays', function () {",
                  "    const data = pm.response.json().data;",
                  "    Object.values(data).forEach(v => pm.expect(v).to.be.an('array'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/matches/filter-options", "host": ["{{baseUrl}}"], "path": ["api","matches","filter-options"] }
          }
        }
      ]
    },

    {
      "name": "🔍 MATCHES — Get Matches",
      "item": [
        {
          "name": "1. Get All Matches (no filters, default sort)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Meta pagination fields exist', function () {",
                  "    const { meta } = pm.response.json();",
                  "    pm.expect(meta).to.have.all.keys('total','page','limit','totalPages','hasNextPage','hasPrevPage');",
                  "});",
                  "pm.test('Data is an array', function () {",
                  "    pm.expect(pm.response.json().data).to.be.an('array');",
                  "});",
                  "pm.test('Each match has matchPercentage', function () {",
                  "    const data = pm.response.json().data;",
                  "    if (data.length > 0) {",
                  "        pm.expect(data[0]).to.have.property('matchPercentage');",
                  "        pm.expect(data[0].matchPercentage).to.be.a('number');",
                  "    }",
                  "});",
                  "pm.test('Each match has computed age', function () {",
                  "    const data = pm.response.json().data;",
                  "    if (data.length > 0 && data[0].dob) {",
                  "        pm.expect(data[0]).to.have.property('age');",
                  "    }",
                  "});",
                  "pm.test('Password is not exposed', function () {",
                  "    const data = pm.response.json().data;",
                  "    if (data.length > 0) {",
                  "        pm.expect(data[0]).to.not.have.property('password');",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/matches", "host": ["{{baseUrl}}"], "path": ["api","matches"] }
          }
        },

        {
          "name": "2. Get Matches — Sort by Newest",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array sorted newest first', function () {",
                  "    const data = pm.response.json().data;",
                  "    if (data.length >= 2) {",
                  "        const d1 = new Date(data[0].createdAt).getTime();",
                  "        const d2 = new Date(data[1].createdAt).getTime();",
                  "        pm.expect(d1).to.be.at.least(d2);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches?sortBy=newest",
              "host": ["{{baseUrl}}"], "path": ["api","matches"],
              "query": [{ "key": "sortBy", "value": "newest" }]
            }
          }
        },

        {
          "name": "3. Get Matches — Sort by Oldest",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array sorted oldest first', function () {",
                  "    const data = pm.response.json().data;",
                  "    if (data.length >= 2) {",
                  "        const d1 = new Date(data[0].createdAt).getTime();",
                  "        const d2 = new Date(data[1].createdAt).getTime();",
                  "        pm.expect(d1).to.be.at.most(d2);",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/matches?sortBy=oldest",
              "host": ["{{baseUrl}}"], "path": ["api","matches"],
              "query": [{ "key": "sortBy", "value": "oldest" }]
            }
          }
        },

        {
          "name": "4. Get Matches — Paginated (Page 1, Limit 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
