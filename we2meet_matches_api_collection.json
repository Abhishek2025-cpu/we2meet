    {
      "name": "📤 MATCHES — POST /filter (body-based)",
      "item": [
        {
          "name": "11. POST Filter — Basic (no filters)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns data array', () => pm.expect(pm.response.json().data).to.be.an('array'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": { "raw": "{{baseUrl}}/api/matches/filter", "host": ["{{baseUrl}}"], "path": ["api","matches","filter"] }
          }
        },

        {
          "name": "12. POST Filter — Full Preferences Object",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Data is an array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('Meta pagination returned', () => pm.expect(pm.response.json().meta).to.have.property('total'));"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"ageMin\": 21,\n  \"ageMax\": 35,\n  \"heightMin\": 150,\n  \"heightMax\": 185,\n  \"religions\": [\"Hindu\", \"Jain\"],\n  \"motherTongues\": [\"Hindi\", \"Gujarati\"],\n  \"castes\": [\"Brahmin\", \"Kshatriya\"],\n  \"qualifications\": [\"B.Tech\", \"MBA\", \"M.Tech\"],\n  \"workingWith\": [\"Private Company\", \"Business\"],\n  \"professions\": [\"Software Engineer\", \"Doctor\"],\n  \"annualIncomeMin\": 400000,\n  \"annualIncomeMax\": 2000000,\n  \"dietaryPreference\": [\"Vegetarian\"],\n  \"smoking\": false,\n  \"drinking\": false,\n  \"familyStatus\": [\"Middle Class\", \"Upper Middle Class\"],\n  \"familyType\": [\"Nuclear Family\"],\n  \"familyValues\": [\"Traditional\", \"Moderate\"],\n  \"manglik\": false,\n  \"maritalStatus\": [\"Never Married\"],\n  \"minMatchPercentage\": 0,\n  \"sortBy\": \"matchPercentage\",\n  \"page\": 1,\n  \"limit\": 20\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/matches/filter", "host": ["{{baseUrl}}"], "path": ["api","matches","filter"] }
          }
